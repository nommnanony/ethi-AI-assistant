{
  "name": "ethi-ai-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Ethi AI Desktop Assistant",
  "type": "module",
  "main": "electron-dist/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"node scripts/wait-and-electron.cjs\"",
    "dev:vite": "vite",
    "dev:electron": "node scripts/wait-and-electron.cjs",
    "build": "tsc -p tsconfig.json && vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/rename-electron.mjs",
    "build:all": "pnpm build && pnpm build:electron",
    "dist": "pnpm build:all && electron-builder --win --x64",
    "dist:portable": "pnpm build:all && electron-builder --win portable --x64",
    "dist:dir": "pnpm build:all && electron-builder --win --dir",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist electron-dist node_modules .turbo"
  },
  "build": {
    "appId": "ai.ethi-ai.desktop",
    "productName": "Ethi AI",
    "copyright": "Copyright (c) 2026 Ethi AI",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "exe-output-v3"
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": null,
      "artifactName": "ETHI-AI-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ethi AI"
    },
    "extraMetadata": {
      "main": "electron-dist/main.mjs"
    }
  },
  "dependencies": {
    "@ethi/shared": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.32.0",
    "axios": "^1.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "framer-motion": "^11.1.0",
    "lucide-react": "^0.372.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.23.0",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@ethi/eslint-config": "workspace:*",
    "@ethi/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-top-level-await": "^1.4.0",
    "vitest": "^1.4.0",
    "wait-on": "^8.0.0"
  }
}
