{
  "name": "@ethi-ai/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema=src/database/prisma/schema.prisma",
    "db:push": "prisma db push --schema=src/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/database/prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=src/database/prisma/schema.prisma",
    "db:seed": "tsx src/database/seed.ts",
    "db:studio": "prisma studio --schema=src/database/prisma/schema.prisma",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@deepgram/sdk": "^3.3.0",
    "@fastify/compress": "^7.0.0",
    "@fastify/cookie": "^9.0.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/csrf-protection": "^6.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/redis": "^6.0.0",
    "@fastify/static": "^7.0.0",
    "@fastify/swagger": "^8.0.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@fastify/websocket": "^10.0.0",
    "@google/generative-ai": "^0.7.0",
    "@natively/shared": "workspace:*",
    "@prisma/client": "^5.12.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "dayjs": "^1.11.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.26.0",
    "handlebars": "^4.7.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "ms": "^2.1.0",
    "nanoid": "^5.0.0",
    "nodemailer": "^6.9.0",
    "openai": "^4.40.0",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "stripe": "^15.0.0",
    "ws": "^8.20.1",
    "zod": "^3.22.0"
  },
  "prisma": {
    "schema": "src/database/prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/ms": "^0.7.0",
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^6.4.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prisma": "^5.12.0",
    "tsc-alias": "^1.8.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
