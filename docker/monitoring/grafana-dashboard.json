{
  "title": "EthiAI - Backend Overview",
  "tags": ["ethi", "backend"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "title": "Request Rate",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Request Latency (p95)",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{route}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Active WebSocket Connections",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ws_connections_active",
          "legendFormat": "active"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 }
    },
    {
      "title": "Error Rate by Status Code",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[5m])",
          "legendFormat": "5xx"
        },
        {
          "expr": "rate(http_requests_total{status=~\"4..\"}[5m])",
          "legendFormat": "4xx"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 }
    },
    {
      "title": "CPU Usage",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[1m])",
          "legendFormat": "CPU"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 }
    },
    {
      "title": "Memory Usage",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS"
        },
        {
          "expr": "process_heap_bytes",
          "legendFormat": "Heap"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 }
    },
    {
      "title": "Database Connection Pool",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "db_connections_active",
          "legendFormat": "active"
        },
        {
          "expr": "db_connections_idle",
          "legendFormat": "idle"
        },
        {
          "expr": "db_connections_total",
          "legendFormat": "total"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 }
    },
    {
      "title": "AI Provider Latency",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(ai_provider_request_duration_seconds_sum[5m]) / rate(ai_provider_request_duration_seconds_count[5m])",
          "legendFormat": "{{provider}}"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 }
    }
  ]
}
